views:
  - title: Accueil
    path: accueil
    icon: mdi:home
    type: sections
    max_columns: 4
    sections:
      - type: grid
        cards:
          - type: custom:bubble-card
            card_type: separator
            name: La maison
            icon: mdi:home-heart
          - type: custom:bubble-card
            card_type: button
            button_type: state
            entity: person.jouy_le_potier
            name: Nico
            sub_button:
              - entity: sensor.sm_s931u_battery_level
                show_state: true
                show_icon: true
              - entity: sensor.sm_s931u_detected_activity
                show_state: true
                show_icon: true
            tap_action:
              action: more-info
          - type: custom:bubble-card
            card_type: button
            button_type: state
            entity: person.perrine
            name: Perrine
            sub_button:
              - entity: sensor.tel_perrine_battery_level
                show_state: true
                show_icon: true
              - entity: sensor.tel_perrine_detected_activity
                show_state: true
                show_icon: true
            tap_action:
              action: more-info
      - type: grid
        cards:
          - type: custom:bubble-card
            card_type: separator
            name: Meteo
            icon: mdi:weather-partly-cloudy
          - type: weather-forecast
            entity: weather.forecast_maison
            forecast_type: daily
            show_current: true
            show_forecast: true
          - type: horizontal-stack
            cards:
              - type: custom:mushroom-template-card
                primary: Lever
                secondary: >-
                  {{ as_timestamp(states('sensor.sun_next_rising')) |
                  timestamp_custom('%H:%M') }}
                icon: mdi:weather-sunset-up
                icon_color: orange
              - type: custom:mushroom-template-card
                primary: Coucher
                secondary: >-
                  {{ as_timestamp(states('sensor.sun_next_setting')) |
                  timestamp_custom('%H:%M') }}
                icon: mdi:weather-sunset-down
                icon_color: deep-orange
      - type: grid
        cards:
          - type: custom:bubble-card
            card_type: separator
            name: Securite
            icon: mdi:shield-home
          - type: custom:bubble-card
            card_type: button
            button_type: state
            entity: alarm_control_panel.alarmo
            name: Alarme
            tap_action:
              action: more-info
            sub_button:
              - icon: mdi:shield-home
                tap_action:
                  action: call-service
                  service: alarm_control_panel.alarm_arm_home
                  service_data:
                    entity_id: alarm_control_panel.alarmo
                show_background: false
              - icon: mdi:shield-lock
                tap_action:
                  action: call-service
                  service: alarm_control_panel.alarm_arm_away
                  service_data:
                    entity_id: alarm_control_panel.alarmo
                show_background: false
              - icon: mdi:shield-moon
                tap_action:
                  action: call-service
                  service: alarm_control_panel.alarm_arm_night
                  service_data:
                    entity_id: alarm_control_panel.alarmo
                show_background: false
          - type: custom:bubble-card
            card_type: button
            button_type: state
            entity: cover.portail
            name: Portail
            icon: mdi:gate
            tap_action:
              action: call-service
              service: script.turn_on
              service_data:
                entity_id: script.ouverture_du_portail
          - type: custom:mushroom-template-card
            primary: Ouvertures
            secondary: >-
              {% set entities = [
                'binary_sensor.0xa4c138b788944b2b_contact',
                'binary_sensor.0xa4c138664b1bac82_contact',
                'binary_sensor.0xa4c13893a6f5b9b7_contact',
                'binary_sensor.0xa4c138b35ca17149_contact',
                'binary_sensor.0xa4c1387e3f595605_contact',
                'binary_sensor.0xa4c13828f794482c_contact',
                'binary_sensor.0xa4c138ef24f410e9_contact',
                'binary_sensor.0xa4c1388740e7ca6c_contact',
                'binary_sensor.0xa4c138e4a8e7b49f_contact',
                'binary_sensor.capteur_porte_d_entree_porte',
                'binary_sensor.baie_vitree_droite_porte',
                'binary_sensor.baie_vitree_gauche_porte',
                'binary_sensor.capteur_salle_de_bain_porte'
              ] %} {% set ouvertes = entities | select('is_state', 'on') | list
              | count %} {% if ouvertes == 0 %}Tout est ferme {% else %}{{
              ouvertes }} ouverte(s){% endif %}
            icon: >-
              {% set entities = [
                'binary_sensor.0xa4c138b788944b2b_contact',
                'binary_sensor.0xa4c138664b1bac82_contact',
                'binary_sensor.0xa4c13893a6f5b9b7_contact',
                'binary_sensor.0xa4c138b35ca17149_contact',
                'binary_sensor.0xa4c1387e3f595605_contact',
                'binary_sensor.0xa4c13828f794482c_contact',
                'binary_sensor.0xa4c138ef24f410e9_contact',
                'binary_sensor.0xa4c1388740e7ca6c_contact',
                'binary_sensor.0xa4c138e4a8e7b49f_contact'
              ] %} {% set ouvertes = entities | select('is_state', 'on') | list
              | count %} {% if ouvertes == 0 %}mdi:door-closed-lock {% else
              %}mdi:door-open{% endif %}
            icon_color: >-
              {% set entities = [
                'binary_sensor.0xa4c138b788944b2b_contact',
                'binary_sensor.0xa4c138664b1bac82_contact',
                'binary_sensor.0xa4c13893a6f5b9b7_contact',
                'binary_sensor.0xa4c138b35ca17149_contact',
                'binary_sensor.0xa4c1387e3f595605_contact',
                'binary_sensor.0xa4c13828f794482c_contact',
                'binary_sensor.0xa4c138ef24f410e9_contact',
                'binary_sensor.0xa4c1388740e7ca6c_contact',
                'binary_sensor.0xa4c138e4a8e7b49f_contact'
              ] %} {% set ouvertes = entities | select('is_state', 'on') | list
              | count %} {% if ouvertes == 0 %}green {% else %}orange{% endif %}
            tap_action:
              action: navigate
              navigation_path: /lovelace/securite
      - type: grid
        cards:
          - type: custom:bubble-card
            card_type: separator
            name: Climat
            icon: mdi:thermometer
          - type: horizontal-stack
            cards:
              - type: custom:mushroom-template-card
                primary: RDC
                secondary: >-
                  {{ states('sensor.0xa4c138503fcc929f_temperature') }}C - {{
                  states('sensor.0xa4c138503fcc929f_humidity') }}%
                icon: mdi:home-floor-g
                icon_color: >-
                  {% set t = states('sensor.0xa4c138503fcc929f_temperature') |
                  float(0) %} {% if t < 18 %}blue {% elif t < 22 %}green {% elif
                  t < 26 %}orange {% else %}red{% endif %}
              - type: custom:mushroom-template-card
                primary: Etage
                secondary: >-
                  {{ states('sensor.captor_temperature_step_1') }}C - {{
                  states('sensor.captor_humidity_step_1') }}%
                icon: mdi:home-floor-1
                icon_color: >-
                  {% set t = states('sensor.captor_temperature_step_1') |
                  float(0) %} {% if t < 18 %}blue {% elif t < 22 %}green {% elif
                  t < 26 %}orange {% else %}red{% endif %}
          - type: horizontal-stack
            cards:
              - type: custom:mushroom-template-card
                primary: Chambre parents
                secondary: >-
                  {{
                  states('sensor.capteur_de_temperature_et_d_humidite_temperature')
                  }}C - {{
                  states('sensor.capteur_de_temperature_et_d_humidite_humidite')
                  }}%
                icon: mdi:bed
                icon_color: >-
                  {% set t =
                  states('sensor.capteur_de_temperature_et_d_humidite_temperature')
                  | float(0) %} {% if t < 18 %}blue {% elif t < 22 %}green {%
                  elif t < 26 %}orange {% else %}red{% endif %}
              - type: custom:mushroom-template-card
                primary: Chambre Jeanne
                secondary: >-
                  {{ states('sensor.0xa4c13821bc3bee42_temperature') }}C - {{
                  states('sensor.0xa4c13821bc3bee42_humidity') }}%
                icon: mdi:baby-face
                icon_color: >-
                  {% set t = states('sensor.0xa4c13821bc3bee42_temperature') |
                  float(0) %} {% if t < 18 %}blue {% elif t < 22 %}green {% elif
                  t < 26 %}orange {% else %}red{% endif %}
      - type: grid
        cards:
          - type: custom:bubble-card
            card_type: separator
            name: Lumieres
            icon: mdi:lightbulb-group
            sub_button:
              - icon: mdi:lightbulb-off
                tap_action:
                  action: call-service
                  service: light.turn_off
                  service_data:
                    entity_id:
                      - light.lumiere_salon
                      - light.lumiere_cuisine
                      - light.lumiere_salle_a_manger
                      - light.lumiere_chambre_interrupteur_1
                      - light.lumiere_chambre_interrupteur_2
                      - light.lumiere_bureau
                      - light.lumieres_salle_de_bain_interrupteur_1
                      - light.lumieres_salle_de_bain_interrupteur_2
                      - light.lumieres_entree_interrupteur_1
                      - light.lumieres_entree_interrupteur_2
                      - light.lumiere_jardin
          - type: custom:bubble-card
            card_type: button
            button_type: state
            entity: light.lumiere_salon
            name: Salon
            tap_action:
              action: toggle
          - type: custom:bubble-card
            card_type: button
            button_type: state
            entity: light.lumiere_cuisine
            name: Cuisine
            tap_action:
              action: toggle
          - type: custom:bubble-card
            card_type: button
            button_type: state
            entity: light.lumiere_salle_a_manger
            name: Salle a manger
            tap_action:
              action: toggle
          - type: custom:bubble-card
            card_type: button
            button_type: state
            entity: light.lumiere_chambre_interrupteur_1
            name: Chambre
            tap_action:
              action: toggle
          - type: custom:bubble-card
            card_type: button
            button_type: state
            entity: light.lumiere_bureau
            name: Bureau
            tap_action:
              action: toggle
          - type: custom:bubble-card
            card_type: button
            button_type: state
            entity: light.lumiere_jardin
            name: Jardin
            tap_action:
              action: toggle
      - type: grid
        cards:
          - type: custom:bubble-card
            card_type: separator
            name: Volets
            icon: mdi:window-shutter
          - type: horizontal-stack
            cards:
              - type: custom:bubble-card
                card_type: button
                button_type: state
                entity: cover.volet_salon_2
                name: Salon
                icon: mdi:window-shutter
                show_state: false
                show_last_changed: false
                tap_action:
                  action: fire-dom-event
                  browser_mod:
                    service: browser_mod.popup
                    data:
                      title: Volet Salon
                      content:
                        type: vertical-stack
                        cards:
                          - type: horizontal-stack
                            cards:
                              - type: button
                                name: Ouvrir
                                icon: mdi:arrow-up-bold
                                tap_action:
                                  action: call-service
                                  service: input_number.set_value
                                  service_data:
                                    entity_id: input_number.position_cible_volet_salon
                                    value: 100
                              - type: button
                                name: Stop
                                icon: mdi:pause
                                tap_action:
                                  action: call-service
                                  service: input_button.press
                                  service_data:
                                    entity_id: input_button.stop_cover_salon_button
                              - type: button
                                name: Fermer
                                icon: mdi:arrow-down-bold
                                tap_action:
                                  action: call-service
                                  service: input_number.set_value
                                  service_data:
                                    entity_id: input_number.position_cible_volet_salon
                                    value: 0
                          - type: entities
                            entities:
                              - entity: input_number.position_cible_volet_salon
                                name: Position cible
                styles: |
                  .bubble-sub-button-name {
                    font-weight: bold !important;
                  }
                sub_button:
                  - name_template: >-
                      {% set p = state_attr('cover.volet_salon_2',
                      'current_position') | int(0) %} {% set inv = 100 - p %} {%
                      if inv == 0 %}Ferme {% elif inv == 100 %}Ouvert {% else
                      %}{{ inv }}%{% endif %}
                    show_name: true
                    show_background: false
              - type: custom:bubble-card
                card_type: button
                button_type: state
                entity: cover.volet_cuisine_3
                name: Cuisine
                icon: mdi:window-shutter
                show_state: false
                show_last_changed: false
                tap_action:
                  action: fire-dom-event
                  browser_mod:
                    service: browser_mod.popup
                    data:
                      title: Volet Cuisine
                      content:
                        type: vertical-stack
                        cards:
                          - type: horizontal-stack
                            cards:
                              - type: button
                                name: Ouvrir
                                icon: mdi:arrow-up-bold
                                tap_action:
                                  action: call-service
                                  service: input_number.set_value
                                  service_data:
                                    entity_id: input_number.position_cible_volet_cuisine
                                    value: 100
                              - type: button
                                name: Stop
                                icon: mdi:pause
                                tap_action:
                                  action: call-service
                                  service: input_button.press
                                  service_data:
                                    entity_id: input_button.stop_cover_button
                              - type: button
                                name: Fermer
                                icon: mdi:arrow-down-bold
                                tap_action:
                                  action: call-service
                                  service: input_number.set_value
                                  service_data:
                                    entity_id: input_number.position_cible_volet_cuisine
                                    value: 0
                          - type: entities
                            entities:
                              - entity: input_number.position_cible_volet_cuisine
                                name: Position cible
                styles: |
                  .bubble-sub-button-name {
                    font-weight: bold !important;
                  }
                sub_button:
                  - name_template: >-
                      {% set p = state_attr('cover.volet_cuisine_3',
                      'current_position') | int(0) %} {% set inv = 100 - p %} {%
                      if inv == 0 %}Ferme {% elif inv == 100 %}Ouvert {% else
                      %}{{ inv }}%{% endif %}
                    show_name: true
                    show_background: false
      - type: grid
        cards:
          - type: custom:bubble-card
            card_type: separator
            name: Multimedia & Robot
            icon: mdi:remote-tv
          - type: custom:bubble-card
            card_type: media-player
            entity: media_player.televiseur_salon_2
            name: TV Salon
          - type: custom:bubble-card
            card_type: media-player
            entity: media_player.chambre
            name: Chambre
          - type: custom:bubble-card
            card_type: button
            button_type: state
            entity: vacuum.roborock_qv_35a
            name: Roborock
            sub_button:
              - entity: sensor.roborock_qv_35a_batterie
                show_state: true
              - entity: sensor.roborock_qv_35a_etat
                show_state: true
            tap_action:
              action: navigate
              navigation_path: /lovelace/roborock
      - type: grid
        cards:
          - type: custom:bubble-card
            card_type: separator
            name: Chat
            icon: mdi:cat
          - type: custom:mushroom-template-card
            primary: Litiere
            secondary: >-
              {% set last =
              as_timestamp(states('input_datetime.passage_litiere')) %} {% set
              diff = (as_timestamp(now()) - last) / 3600 %} {% if diff < 1
              %}Nettoyee il y a moins d'une heure {% elif diff < 24 %}Nettoyee
              il y a {{ diff | int }}h {% else %}Nettoyee il y a {{ (diff / 24)
              | int }}j{% endif %}
            icon: mdi:cat
            icon_color: >-
              {% set last =
              as_timestamp(states('input_datetime.passage_litiere')) %} {% set
              diff = (as_timestamp(now()) - last) / 3600 %} {% if diff < 24
              %}green {% elif diff < 48 %}orange {% else %}red{% endif %}
            tap_action:
              action: call-service
              service: button.press
              target:
                entity_id: button.roborock_qv_35a_nettoyage_litiere
  - title: Pieces
    path: pieces
    icon: mdi:floor-plan
    type: sections
    max_columns: 3
    sections:
      - type: grid
        cards:
          - type: custom:bubble-card
            card_type: separator
            name: Salon - Salle a manger
            icon: mdi:sofa
          - type: custom:bubble-card
            card_type: button
            button_type: state
            entity: light.lumiere_salon
            name: Salon
            tap_action:
              action: toggle
            double_tap_action:
              action: more-info
          - type: custom:bubble-card
            card_type: button
            button_type: state
            entity: light.lumiere_salle_a_manger
            name: Salle a manger
            tap_action:
              action: toggle
            double_tap_action:
              action: more-info
          - type: custom:bubble-card
            card_type: button
            button_type: state
            entity: input_number.position_volet_salon
            name: Volet Salon
            icon: mdi:window-shutter
            show_state: false
            tap_action:
              action: fire-dom-event
              browser_mod:
                service: browser_mod.popup
                data:
                  title: Volet Salon
                  content:
                    type: vertical-stack
                    cards:
                      - type: horizontal-stack
                        cards:
                          - type: button
                            name: Ouvrir
                            icon: mdi:arrow-up-bold
                            tap_action:
                              action: call-service
                              service: input_number.set_value
                              service_data:
                                entity_id: input_number.position_cible_volet_salon
                                value: 100
                          - type: button
                            name: Stop
                            icon: mdi:pause
                            tap_action:
                              action: call-service
                              service: input_button.press
                              service_data:
                                entity_id: input_button.stop_cover_salon_button
                          - type: button
                            name: Fermer
                            icon: mdi:arrow-down-bold
                            tap_action:
                              action: call-service
                              service: input_number.set_value
                              service_data:
                                entity_id: input_number.position_cible_volet_salon
                                value: 0
                      - type: entities
                        entities:
                          - entity: input_number.position_cible_volet_salon
                            name: Position cible
            sub_button:
              - name_template: >-
                  {% set p = states('input_number.position_volet_salon') | int(0)
                  %} {% if p == 0 %}Ferme {% elif p == 100 %}Ouvert {% else %}{{ p
                  }}%{% endif %}
                show_name: true
                show_background: false
          - type: custom:mushroom-template-card
            primary: RDC
            secondary: >-
              {{ states('sensor.0xa4c138503fcc929f_temperature') }}C - {{
              states('sensor.0xa4c138503fcc929f_humidity') }}% humidite
            icon: mdi:thermometer
            icon_color: >-
              {% set t = states('sensor.0xa4c138503fcc929f_temperature') |
              float(0) %} {% if t < 18 %}blue {% elif t < 22 %}green {% elif t <
              26 %}orange {% else %}red{% endif %}
      - type: grid
        cards:
          - type: custom:bubble-card
            card_type: separator
            name: Cuisine
            icon: mdi:silverware-fork-knife
          - type: custom:bubble-card
            card_type: button
            button_type: state
            entity: light.lumiere_cuisine
            name: Plafonnier
            tap_action:
              action: toggle
          - type: custom:bubble-card
            card_type: button
            button_type: state
            entity: input_number.position_volet_cuisine
            name: Volet Cuisine
            icon: mdi:window-shutter
            show_state: false
            tap_action:
              action: fire-dom-event
              browser_mod:
                service: browser_mod.popup
                data:
                  title: Volet Cuisine
                  content:
                    type: vertical-stack
                    cards:
                      - type: horizontal-stack
                        cards:
                          - type: button
                            name: Ouvrir
                            icon: mdi:arrow-up-bold
                            tap_action:
                              action: call-service
                              service: input_number.set_value
                              service_data:
                                entity_id: input_number.position_cible_volet_cuisine
                                value: 100
                          - type: button
                            name: Stop
                            icon: mdi:pause
                            tap_action:
                              action: call-service
                              service: input_button.press
                              service_data:
                                entity_id: input_button.stop_cover_button
                          - type: button
                            name: Fermer
                            icon: mdi:arrow-down-bold
                            tap_action:
                              action: call-service
                              service: input_number.set_value
                              service_data:
                                entity_id: input_number.position_cible_volet_cuisine
                                value: 0
                      - type: entities
                        entities:
                          - entity: input_number.position_cible_volet_cuisine
                            name: Position cible
            sub_button:
              - name_template: >-
                  {% set p = states('input_number.position_volet_cuisine') |
                  int(0) %} {% if p == 0 %}Ferme {% elif p == 100 %}Ouvert {%
                  else %}{{ p }}%{% endif %}
                show_name: true
                show_background: false
      - type: grid
        cards:
          - type: custom:bubble-card
            card_type: separator
            name: Bureau
            icon: mdi:desk
          - type: custom:bubble-card
            card_type: button
            button_type: state
            entity: light.lumiere_bureau
            name: Bureau
            tap_action:
              action: toggle
      - type: grid
        cards:
          - type: custom:bubble-card
            card_type: separator
            name: Chambre parents
            icon: mdi:bed
          - type: custom:bubble-card
            card_type: button
            button_type: state
            entity: light.lumiere_chambre_interrupteur_1
            name: Luminaire
            tap_action:
              action: toggle
          - type: custom:bubble-card
            card_type: button
            button_type: state
            entity: light.lumiere_chambre_interrupteur_2
            name: Spot
            tap_action:
              action: toggle
          - type: custom:bubble-card
            card_type: media-player
            entity: media_player.chambre
            name: Chambre
          - type: custom:mushroom-template-card
            primary: Chambre parents
            secondary: >-
              {{
              states('sensor.capteur_de_temperature_et_d_humidite_temperature')
              }}C - {{
              states('sensor.capteur_de_temperature_et_d_humidite_humidite') }}%
              humidite
            icon: mdi:thermometer
            icon_color: >-
              {% set t =
              states('sensor.capteur_de_temperature_et_d_humidite_temperature')
              | float(0) %} {% if t < 18 %}blue {% elif t < 22 %}green {% elif t
              < 26 %}orange {% else %}red{% endif %}
      - type: grid
        cards:
          - type: custom:bubble-card
            card_type: separator
            name: Chambre Jeanne
            icon: mdi:baby-face
          - type: custom:mushroom-template-card
            primary: Chambre Jeanne
            secondary: >-
              {{ states('sensor.0xa4c13821bc3bee42_temperature') }}C - {{
              states('sensor.0xa4c13821bc3bee42_humidity') }}% humidite
            icon: mdi:thermometer
            icon_color: >-
              {% set t = states('sensor.0xa4c13821bc3bee42_temperature') |
              float(0) %} {% if t < 18 %}blue {% elif t < 22 %}green {% elif t <
              26 %}orange {% else %}red{% endif %}
      - type: grid
        cards:
          - type: custom:bubble-card
            card_type: separator
            name: Salle de bain
            icon: mdi:shower
          - type: custom:bubble-card
            card_type: button
            button_type: state
            entity: light.lumieres_salle_de_bain_interrupteur_1
            name: Lumiere 1
            tap_action:
              action: toggle
          - type: custom:bubble-card
            card_type: button
            button_type: state
            entity: light.lumieres_salle_de_bain_interrupteur_2
            name: Lumiere 2
            tap_action:
              action: toggle
      - type: grid
        cards:
          - type: custom:bubble-card
            card_type: separator
            name: Etage
            icon: mdi:home-floor-1
          - type: custom:mushroom-template-card
            primary: Palier etage
            secondary: >-
